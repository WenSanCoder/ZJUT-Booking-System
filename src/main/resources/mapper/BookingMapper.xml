<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rainbowmaodie.zjutbookingsystem.mapper.BookingMapper">
    <select id="selectBookingVOPage" resultType="com.rainbowmaodie.zjutbookingsystem.vo.BookingVO">
        SELECT 
            b.*,
            u.real_name as applicant_name,
            u.username as applicant_username,
            u.phone,
            v.name as venue_name
        FROM booking b
        LEFT JOIN user u ON b.user_id = u.id
        LEFT JOIN venue v ON b.venue_id = v.id
        <where>
            <if test="applicant != null and applicant != ''">
                AND (u.username LIKE CONCAT('%', #{applicant}, '%') OR u.real_name LIKE CONCAT('%', #{applicant}, '%'))
            </if>
            <if test="status != null and status != ''">
                AND b.status = #{status}
            </if>
            <if test="startDate != null and startDate != ''">
                AND b.start_time &gt;= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                AND b.start_time &lt;= #{endDate}
            </if>
            <if test="buildingIds != null and buildingIds.size() > 0">
                AND v.building_id IN
                <foreach collection="buildingIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>
        ORDER BY b.created_at DESC
    </select>
</mapper>
